# VINCI AI Video Editor - Environment Variables

# Server Configuration
PORT=3000
NODE_ENV=production

# Storage Configuration
MAX_UPLOAD_SIZE=500mb
UPLOAD_DIR=uploads
OUTPUT_DIR=outputs
AVATAR_DIR=avatars

# Supabase Configuration (Optional Free Tier)
# Get these from your Supabase Project Settings > API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Local AI Model Configuration (Optional)
# Set paths to local model weights if needed
WHISPER_MODEL_PATH=
COQUI_TTS_MODEL_PATH=
WAV2LIP_CHECKPOINT_PATH=
