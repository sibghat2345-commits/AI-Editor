# VINCI AI Video Editor - Environment Configuration

# Server Port
PORT=3000

# Local LLM Configuration (Ollama)
# Default: http://localhost:11434/api/generate
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3

# Supabase Configuration (Optional - for cloud sync)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Local AI Paths (Optional - for custom setups)
# WAV2LIP_DIR=/path/to/Wav2Lip
# WAV2LIP_CHECKPOINT=/path/to/checkpoint.pth
